#!/usr/bin/env bash
set -uo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
[ -f "$repo_root/build.ps1" ] || exit 0

pwsh_bin=""
for c in pwsh pwsh.exe powershell.exe powershell; do
  if command -v "$c" >/dev/null 2>&1; then pwsh_bin="$c"; break; fi
done

if [ -z "$pwsh_bin" ]; then
  echo "pre-push: PowerShell not found; skipping build check." >&2
  exit 0
fi

if ! command -v dotnet >/dev/null 2>&1; then
  echo "pre-push: dotnet not found; skipping build check." >&2
  exit 0
fi

echo "pre-push: running build.ps1..." >&2
"$pwsh_bin" -NoProfile -ExecutionPolicy Bypass -File "$repo_root/build.ps1"
if [ "$?" -ne 0 ]; then
  echo "pre-push BLOCKED: build.ps1 failed." >&2
  exit 1
fi

echo "pre-push: build check passed." >&2
exit 0
