<Window x:Class="VRCInventoryManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        Title="VRCInventoryManager"
        Width="1380"
        Height="820"
        MinWidth="1040"
        MinHeight="650"
        Background="#111318"
        Foreground="#F4F4F5"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinHeight" Value="32" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,6,0,8" />
            <Setter Property="Padding" Value="8,5" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#171A21" />
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="BorderBrush" Value="#303642" />
        </Style>
        <Style TargetType="ListView">
            <Setter Property="Background" Value="#171A21" />
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="BorderBrush" Value="#303642" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="390" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,14,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Local Library" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                <ComboBox x:Name="FolderCombo" Height="32" SelectionChanged="FolderCombo_SelectionChanged" />
                <DockPanel Margin="0,8,0,0">
                    <Button Content="Browse" Click="Browse_Click" DockPanel.Dock="Left" />
                    <Button Content="Refresh" Click="RefreshLocal_Click" DockPanel.Dock="Left" />
                    <TextBlock x:Name="LocalCountText" VerticalAlignment="Center" Foreground="#B7BDC8" />
                </DockPanel>
                <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged" />
                <TextBlock x:Name="CurrentFolderText" TextWrapping="Wrap" Foreground="#B7BDC8" FontSize="12" Margin="0,0,0,8" />
            </StackPanel>

            <ListBox x:Name="LocalAssetList"
                     Grid.Row="1"
                     SelectionChanged="LocalAssetList_SelectionChanged"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="58" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Grid.RowSpan="2"
                                    Width="52"
                                    Height="52"
                                    Margin="0,0,8,0"
                                    Background="#0B0D12"
                                    BorderBrush="#303642"
                                    BorderThickness="1">
                                <Image Source="{Binding Path}" Stretch="Uniform" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding Name}" TextTrimming="CharacterEllipsis" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DetailsText}" Foreground="#B7BDC8" FontSize="12" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Grid Grid.Column="1" Margin="0,0,14,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border BorderBrush="#303642" BorderThickness="1" Background="#0B0D12">
                <wfi:WindowsFormsHost x:Name="PreviewHost" />
            </Border>

            <TextBlock x:Name="SelectedFileText"
                       Grid.Row="1"
                       Margin="0,10,0,8"
                       TextWrapping="Wrap"
                       Foreground="#D7DBE3" />

            <WrapPanel Grid.Row="2">
                <Button x:Name="UploadStickerButton" Content="Upload Sticker" Click="UploadSticker_Click" />
                <Button x:Name="UploadEmojiButton" Content="Upload Emoji" Click="UploadEmoji_Click" />
                <Button x:Name="UploadAnimatedEmojiButton" Content="Upload Animated Emoji" Click="UploadAnimatedEmoji_Click" />
                <TextBlock x:Name="ActionStatusText" VerticalAlignment="Center" Foreground="#B7BDC8" />
            </WrapPanel>
        </Grid>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="VRChat Inventory" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                <TextBlock x:Name="ConnectionStatusText" Foreground="#B7BDC8" TextWrapping="Wrap" />
                <TextBlock x:Name="RemoteCountText" Foreground="#D7DBE3" Margin="0,6,0,8" />
                <DockPanel>
                    <Button Content="Reconnect" Click="Reconnect_Click" DockPanel.Dock="Left" />
                    <Button Content="Refresh" Click="RefreshRemote_Click" DockPanel.Dock="Left" />
                </DockPanel>
            </StackPanel>

            <ListView x:Name="RemoteFileList" Grid.Row="1" Margin="0,10,0,10" SelectionChanged="RemoteFileList_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding DisplayType}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="1" Text="{Binding Summary}" Foreground="#B7BDC8" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Row="2" Text="{Binding Id}" Foreground="#8C94A3" FontSize="12" TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel Grid.Row="2">
                <TextBlock x:Name="RemoteSelectedText" Foreground="#B7BDC8" TextWrapping="Wrap" Margin="0,0,0,8" />
                <Button x:Name="DeleteRemoteButton" Content="Delete Remote File" Click="DeleteRemote_Click" HorizontalAlignment="Left" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
