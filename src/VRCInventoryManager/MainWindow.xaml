<Window x:Class="VRCInventoryManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:VRCInventoryManager"
        Title="VRCInventoryManager"
        Icon="Assets/AppIcon.ico"
        Width="1360"
        Height="800"
        MinWidth="1120"
        MinHeight="660"
        WindowStartupLocation="CenterScreen"
        Background="#101114"
        Foreground="#F7F5EF"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/AppTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="14" Style="{StaticResource PanelBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="VRC Inventory Manager" FontSize="23" FontWeight="SemiBold" />
                    <TextBlock x:Name="HeaderStatusText"
                               Text="Starting"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Reconnect" Click="Reconnect_Click" Style="{StaticResource PrimaryButton}" Margin="0" />
                </StackPanel>
            </Grid>
        </Border>

        <ProgressBar x:Name="BusyBar"
                     Grid.Row="0"
                     Height="2"
                     VerticalAlignment="Bottom"
                     IsIndeterminate="True"
                     Foreground="{StaticResource AccentBrush}"
                     Visibility="Collapsed" />

        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="390" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Margin="0,0,14,0">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="0.34*" MinHeight="120" MaxHeight="220" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <TextBlock Text="Local files" Style="{StaticResource SectionTitle}" />
                        <TextBlock x:Name="LocalCountText"
                                   DockPanel.Dock="Right"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </DockPanel>

                    <StackPanel Grid.Row="1" Margin="0,8,0,12">
                        <TextBlock Text="Folder" Style="{StaticResource FieldLabel}" />
                        <ComboBox x:Name="FolderCombo" SelectionChanged="FolderCombo_SelectionChanged" />
                        <DockPanel Margin="0,8,0,0">
                            <Button Content="Browse" Click="Browse_Click" DockPanel.Dock="Left" />
                            <Button Content="Refresh" Click="RefreshLocal_Click" DockPanel.Dock="Left" />
                            <TextBlock x:Name="CurrentFolderText"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                        <TextBlock Text="Search" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged" />
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="Folders" Style="{StaticResource FieldLabel}" Margin="0" />
                            <CheckBox x:Name="IncludeSubfoldersCheckBox"
                                      DockPanel.Dock="Right"
                                      Content="Include subfolders"
                                      IsChecked="True"
                                      Checked="IncludeSubfolders_Changed"
                                      Unchecked="IncludeSubfolders_Changed" />
                        </DockPanel>
                        <TreeView x:Name="FolderTree"
                                  Grid.Row="1"
                                  SelectedItemChanged="FolderTree_SelectedItemChanged">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <DockPanel LastChildFill="True" ToolTip="{Binding FullPath}">
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding CountText}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Margin="8,0,0,0" />
                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                    </DockPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>

                    <Grid Grid.Row="3">
                        <ListBox x:Name="LocalAssetList"
                                 ItemContainerStyle="{StaticResource GalleryItemStyle}"
                                 ScrollViewer.CanContentScroll="True"
                                 SelectionChanged="LocalAssetList_SelectionChanged">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <local:VirtualizingTilePanel ItemWidth="120" ItemHeight="154" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="108" Height="142">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="104" />
                                            <RowDefinition Height="22" />
                                            <RowDefinition Height="16" />
                                        </Grid.RowDefinitions>
                                        <Grid.ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding FolderName}" />
                                                <TextBlock Text="{Binding DetailsText}" />
                                            </StackPanel>
                                        </Grid.ToolTip>
                                        <Border Width="104"
                                                Height="104"
                                                Background="#0C0D0B"
                                                BorderBrush="{StaticResource BorderBrushStrong}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <Image Source="{Binding Thumbnail}"
                                                   Stretch="Uniform"
                                                   SnapsToDevicePixels="True"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Loaded="LocalThumbnail_Loaded"
                                                   DataContextChanged="LocalThumbnail_DataContextChanged" />
                                        </Border>
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Name}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Bottom"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Grid.Row="2"
                                                   Text="{Binding TileMeta}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock x:Name="LocalEmptyText"
                                   Text="No images found."
                                   Visibility="Collapsed"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="0,0,14,0">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SelectedFileTitle"
                                   Text="Preview"
                                   Style="{StaticResource SectionTitle}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="SelectedFileText"
                                   Grid.Column="1"
                                   HorizontalAlignment="Right"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>

                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource BorderBrushStrong}"
                            BorderThickness="1"
                            Background="#0C0D0B"
                            CornerRadius="8">
                        <Grid>
                            <Image x:Name="PreviewImage"
                                   Stretch="Uniform"
                                   SnapsToDevicePixels="True"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                            <TextBlock x:Name="PreviewEmptyText"
                                       Text="Select a local image."
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedTextBrush}" />
                        </Grid>
                    </Border>

                    <DockPanel Grid.Row="2" Margin="0,12,0,0">
                        <TextBlock x:Name="ActionStatusText"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <Button x:Name="UploadStickerButton"
                                    Content="Upload Sticker"
                                    Click="UploadSticker_Click"
                                    Style="{StaticResource PrimaryButton}" />
                            <Button x:Name="UploadEmojiButton"
                                    Content="Upload Emoji"
                                    Click="UploadEmoji_Click"
                                    Style="{StaticResource PrimaryButton}" />
                            <Button x:Name="UploadAnimatedEmojiButton"
                                    Content="Upload Animated Emoji"
                                    Click="UploadAnimatedEmoji_Click"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0" />
                        </WrapPanel>
                    </DockPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="VRChat inventory" Style="{StaticResource SectionTitle}" />
                            <Button Content="Refresh" Click="RefreshRemote_Click" DockPanel.Dock="Right" HorizontalAlignment="Right" Margin="8,0,0,0" />
                        </DockPanel>
                        <TextBlock x:Name="ConnectionStatusText"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                        <TextBlock x:Name="RemoteCountText"
                                   Foreground="{StaticResource SoftTextBrush}"
                                   Margin="0,6,0,0" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,12,0,12">
                        <ListView x:Name="RemoteFileList" SelectionChanged="RemoteFileList_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="74" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Border Grid.RowSpan="3"
                                                Width="66"
                                                Height="66"
                                                Margin="0,0,10,0"
                                                Background="#0C0D0B"
                                                BorderBrush="{StaticResource BorderBrushStrong}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <Image Source="{Binding Thumbnail}"
                                                   Stretch="Uniform"
                                                   Loaded="RemoteThumbnail_Loaded"
                                                   DataContextChanged="RemoteThumbnail_DataContextChanged" />
                                        </Border>
                                        <DockPanel Grid.Column="1">
                                            <TextBlock Text="{Binding DisplayType}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Status}"
                                                       DockPanel.Dock="Right"
                                                       HorizontalAlignment="Right"
                                                       Foreground="{StaticResource WarningBrush}"
                                                       FontSize="12" />
                                        </DockPanel>
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   Text="{Binding Summary}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="1"
                                                   Text="{Binding Id}"
                                                   Foreground="#908A7E"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock x:Name="RemoteEmptyText"
                                   Text="No remote files loaded."
                                   Visibility="Collapsed"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </Grid>

                    <StackPanel Grid.Row="2">
                        <TextBlock x:Name="RemoteSelectedText"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <Button x:Name="DeleteRemoteButton"
                                Content="Delete Remote File"
                                Click="DeleteRemote_Click"
                                Style="{StaticResource DangerButton}"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
